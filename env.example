# Spending Transaction Monitor Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=spending-monitor
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/spending-monitor

# =============================================================================
# API Configuration
# =============================================================================
API_PORT=8000
ENVIRONMENT=development
BYPASS_AUTH=true
DEBUG=false

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=["http://localhost:3000"]

# =============================================================================
# LLM Provider Configuration (for chat/completions)
# Set LLM_PROVIDER to: openai, llamastack, or vertexai
# =============================================================================
LLM_PROVIDER=openai

# OpenAI settings (when LLM_PROVIDER=openai)
BASE_URL=https://api.openai.com/v1
API_KEY=your-openai-api-key-here
MODEL=gpt-3.5-turbo

# LlamaStack settings (when LLM_PROVIDER=llamastack)
LLAMASTACK_BASE_URL=http://localhost:8321
LLAMASTACK_MODEL=meta-llama/Llama-3.2-3B-Instruct

# VertexAI settings (when LLM_PROVIDER=vertexai)
# Add the following files to the ~/.vertexai folder: sa.json, config.json

# =============================================================================
# Embedding Provider Configuration (for category normalization)
# Set EMBEDDING_PROVIDER to: ollama, openai, or llamastack
# =============================================================================
EMBEDDING_PROVIDER=ollama

# Ollama settings (when EMBEDDING_PROVIDER=ollama) - Recommended
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=all-minilm:l6-v2
EMBEDDING_DIMENSIONS=384

# OpenAI embeddings (when EMBEDDING_PROVIDER=openai)
# Uses same API_KEY and BASE_URL as LLM config above
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# LlamaStack embeddings (when EMBEDDING_PROVIDER=llamastack)
# Uses same LLAMASTACK_BASE_URL as LLM config above
# Will be available when LlamaStack adds embedding API support

NODE_ENV=development

# =============================================================================
# Keycloak Authentication (Optional - only if using Keycloak)
# =============================================================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=spending-monitor
KEYCLOAK_CLIENT_ID=spending-monitor

# =============================================================================
# SMTP Configuration (for email notifications)
# =============================================================================
SMTP_HOST=smtp4dev
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=spending-monitor@localhost
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# =============================================================================
# UI Configuration
# =============================================================================
VITE_API_BASE_URL=/api

